                240,
                300
            ],
            "webhookId": "pet-status"
        },
        {
            "parameters": {
                "jsCode": "const pet = $json.petName || 'seu pet';\nconst service = $json.serviceName || 'serviço';\nconst phone = ($json.tutorPhone || '').replace(/\\D/g, '');\nconst phone55 = phone.startsWith('55') ? phone : '55' + phone;\nconst status = $json.newStatus ? String($json.newStatus).trim().toLowerCase() : \"\";\n\nlet msg = `✅ *${pet}* está pronto! O *${service}* foi concluído com sucesso. Pode vir buscar ele! 🐶❤️`;\nif (status === 'in_progress') {\n  msg = `🛁 Olá! O *${service}* do *${pet}* acabou de INICIAR! Assim que ele estiver pronto, te avisamos aqui. 🐾`;\n}\n\nreturn [{\n  json: {\n    phone: phone55,\n    message: msg\n  }\n}];"
            },
            "id": "msg-builder",
            "name": "Gerar Mensagem",
            "type": "n8n-nodes-base.code",
            "typeVersion": 2,
            "position": [
                500,
                300
            ]
        },
        {
