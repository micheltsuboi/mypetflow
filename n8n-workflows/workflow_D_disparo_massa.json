        "jsCode": "const body = $input.first().json.body || {};\nconst recipients = body.recipients || [];\nconst wa_integration_type = body.wa_integration_type || 'system';\nconst wa_api_url = body.wa_api_url || '';\nconst wa_api_token = body.wa_api_token || '';\nconst wa_client_token = body.wa_client_token || '';\n\nreturn recipients.map(r => {\n  return {\n    json: {\n      phone: r.phone,\n      message: r.message,\n      wa_integration_type,\n      wa_api_url,\n      wa_api_token,\n      wa_client_token\n    }\n  };\n});"
      },
